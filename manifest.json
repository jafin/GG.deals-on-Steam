{
    "manifest_version": 3,
    "name": "GG.deals on Steam",
    "version": "1.0",
    "author": ["Juzlus"],
    "icons": {
        "128": "icons/128.png"
    },
    "description": "An extension for Steam that displays the current lowest prices from GG.deals directly on the games pages.",
    "permissions": [
        "notifications",
        "tabs",
        "storage",
        "unlimitedStorage",
        "declarativeNetRequestWithHostAccess",
        "declarativeNetRequestFeedback"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "128": "icons/128.png"
        }
    },
    "host_permissions": [
        "https://store.steampowered.com/*"
    ],
    "background": {
        "service_worker": "scripts/background.js"
    },
    "web_accessible_resources": [
        {
            "resources": [ "popup.html", "icons/*.png" ],
            "matches": [ "https://store.steampowered.com/*" ]
        }
    ],
    "content_scripts": [
        {
            "matches": [
                "https://store.steampowered.com/*"
            ],
            "js":[
                "scripts/main.js"
            ],
            "css":[
                "css/style.css"
            ]
        },
        {
            "matches": [
                "https://store.steampowered.com/app/*"
            ],
            "js":[
                "scripts/main.js",
                "scripts/app.js"
            ],
            "css":[
                "css/style.css"
            ]
        },
        {
            "matches": [
                "https://store.steampowered.com/recommended/morelike/app/*",
                "https://store.steampowered.com/recommended/morelike/bundle/*"
            ],
            "js":[
                "scripts/main.js",
                "scripts/recommended.js"
            ],
            "css":[
                "css/style.css"
            ]
        },
        {
            "matches": [
                "https://store.steampowered.com/wishlist/*"
            ],
            "js":[
                "scripts/main.js",
                "scripts/wishlist.js"
            ],
            "css":[
                "css/style.css"
            ]
        },
        {
            "matches": [
                "https://store.steampowered.com/cart"
            ],
            "js":[
                "scripts/main.js",
                "scripts/cart.js"
            ],
            "css":[
                "css/style.css"
            ]
        },
        {
            "matches": [
                "https://store.steampowered.com/search/*"
            ],
            "js":[
                "scripts/main.js",
                "scripts/search.js"
            ],
            "css":[
                "css/style.css"
            ]
        },
        {
            "matches": [
                "https://store.steampowered.com/bundle/*"
            ],
            "js":[
                "scripts/main.js",
                "scripts/bundle.js"
            ],
            "css":[
                "css/style.css"
            ]
        }
    ]
}